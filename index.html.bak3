<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>NexTrade — הבורסה הישראלית</title>
  <script src="https://unpkg.com/lightweight-charts/dist/lightweight-charts.standalone.production.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg:#0b0e17; --surface:#131722; --surface2:#1a1f2e; --border:#252d3d;
      --accent:#cadf919f; --green:#26a69a; --red:#ef5350; --text:#d1d4dc;
      --text-muted:#6b7280; --gold:#f5a623;
    }
    body { font-family:'Heebo',sans-serif; background:var(--bg); color:var(--text); min-height:100vh; overflow-x:hidden; }

    /*  AUTH  */
    #authOverlay {
      position:fixed; inset:0; background:var(--bg); z-index:9999;
      display:flex; align-items:center; justify-content:center;
    }
    .auth-glow {
      position:absolute; width:600px; height:600px;
      background:radial-gradient(circle,rgba(41,98,255,.15) 0%,transparent 70%);
      top:50%; left:50%; transform:translate(-50%,-50%); pointer-events:none;
    }
    .auth-card {
      position:relative; background:var(--surface); border:1px solid var(--border);
      border-radius:20px; padding:2.5rem 2.25rem; width:100%; max-width:420px;
      box-shadow:0 25px 60px rgba(0,0,0,.5);
    }
    .auth-logo { text-align:center; font-size:2rem; font-weight:700; color:var(--accent); margin-bottom:.25rem; letter-spacing:-1px; }
    .auth-logo span { color:var(--gold); }
    .auth-tagline { text-align:center; font-size:.8rem; color:var(--text-muted); margin-bottom:2rem; }

    .auth-tabs { display:flex; background:var(--surface2); border-radius:10px; padding:4px; margin-bottom:1.75rem; gap:4px; }
    .auth-tab { flex:1; text-align:center; padding:.5rem; font-size:.85rem; font-weight:600; cursor:pointer; border-radius:7px; color:var(--text-muted); transition:all .2s; user-select:none; }
    .auth-tab.active { background:var(--accent); color:#fff; }

    .auth-form { display:flex; flex-direction:column; gap:1rem; }
    .auth-form.hidden { display:none; }

    .field-group { display:flex; flex-direction:column; gap:.4rem; }
    .field-group label { font-size:.78rem; color:var(--text-muted); font-weight:600; }
    .field-group input {
      background:var(--surface2); border:1px solid var(--border); border-radius:10px;
      padding:.7rem 1rem; color:var(--text); font-size:.88rem; font-family:'Heebo',sans-serif;
      direction:rtl; transition:border-color .2s; width:100%;
    }
    .field-group input:focus { outline:none; border-color:var(--accent); box-shadow:0 0 0 3px rgba(41,98,255,.15); }
    .field-group input::placeholder { color:var(--text-muted); }

    /* עין סיסמה */
    .pw-wrap { position:relative; }
    .pw-wrap input { padding-left:2.8rem; padding-right:1rem; }
    .eye-btn {
      position:absolute; left:.8rem; top:50%; transform:translateY(-50%);
      background:none; border:none; cursor:pointer; padding:0;
      color:var(--text-muted); display:flex; align-items:center; transition:color .2s;
    }
    .eye-btn:hover { color:var(--accent); }
    .eye-btn svg { width:18px; height:18px; display:block; }

    .strength-bar { height:3px; border-radius:2px; background:var(--border); margin-top:.4rem; overflow:hidden; }
    .strength-fill { height:100%; border-radius:2px; transition:width .3s,background .3s; width:0%; }
    .strength-text { font-size:.7rem; color:var(--text-muted); margin-top:.25rem; }

    .msg-error { background:rgba(239,83,80,.12); border:1px solid rgba(239,83,80,.3); border-radius:8px; padding:.6rem .9rem; font-size:.8rem; color:var(--red); display:none; }
    .msg-error.show { display:block; }
    .msg-ok { background:rgba(38,166,154,.12); border:1px solid rgba(38,166,154,.3); border-radius:8px; padding:.6rem .9rem; font-size:.8rem; color:var(--green); display:none; }
    .msg-ok.show { display:block; }

    .auth-btn {
      background:var(--accent); color:#fff; border:none; border-radius:10px;
      padding:.75rem; font-size:.9rem; font-weight:700; font-family:'Heebo',sans-serif;
      cursor:pointer; transition:opacity .2s,transform .1s; margin-top:.25rem; width:100%;
    }
    .auth-btn:hover { opacity:.88; }
    .auth-btn:active { transform:scale(.98); }

    .auth-divider { display:flex; align-items:center; gap:.75rem; margin:.25rem 0; color:var(--text-muted); font-size:.75rem; }
    .auth-divider::before,.auth-divider::after { content:''; flex:1; height:1px; background:var(--border); }

    .demo-btn {
      background:transparent; border:1px solid var(--border); color:var(--text-muted);
      border-radius:10px; padding:.65rem; font-size:.82rem; font-family:'Heebo',sans-serif;
      cursor:pointer; transition:all .2s; width:100%;
    }
    .demo-btn:hover { border-color:var(--gold); color:var(--gold); }

    .forgot-link { text-align:center; margin-top:.25rem; }
    .forgot-link a { font-size:.78rem; color:var(--text-muted); cursor:pointer; text-decoration:underline; }
    .forgot-link a:hover { color:var(--accent); }

    .back-link { font-size:.78rem; color:var(--text-muted); cursor:pointer; text-decoration:underline; display:inline-block; margin-bottom:1rem; }
    .back-link:hover { color:var(--accent); }

    .auth-footer { text-align:center; font-size:.72rem; color:var(--text-muted); margin-top:1.5rem; }

    /*  USER BADGE  */
    .user-badge { display:flex; align-items:center; gap:.6rem; }
    .user-avatar { width:32px; height:32px; border-radius:50%; background:var(--accent); display:flex; align-items:center; justify-content:center; font-size:.8rem; font-weight:700; color:#fff; }
    .user-name { font-size:.82rem; color:var(--text-muted); }
    .logout-btn { background:transparent; border:1px solid var(--border); color:var(--text-muted); border-radius:7px; padding:.3rem .65rem; font-size:.75rem; font-family:'Heebo',sans-serif; cursor:pointer; transition:all .2s; }
    .logout-btn:hover { border-color:var(--red); color:var(--red); }

    /*  TICKER  */
    .ticker-wrap { background:var(--surface); border-bottom:1px solid var(--border); overflow:hidden; height:36px; display:flex; align-items:center; }
    .ticker-inner { display:inline-block; white-space:nowrap; animation:ticker 60s linear infinite; font-size:.78rem; color:var(--text-muted); padding-right:100%; }
    .ticker-inner span.up { color:var(--green); }
    .ticker-inner span.down { color:var(--red); }
    @keyframes ticker { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }

    /*  TOPBAR  */
    .topbar { background:var(--surface); border-bottom:1px solid var(--border); padding:0 1.5rem; height:60px; display:flex; align-items:center; justify-content:space-between; position:sticky; top:0; z-index:100; }
    .logo { font-size:1.4rem; font-weight:700; color:var(--accent); letter-spacing:-.5px; }
    .logo span { color:var(--gold); }
    .topbar-center { display:flex; gap:.5rem; align-items:center; }
    .topbar-right  { display:flex; gap:.75rem; align-items:center; }
    .search-box input { background:var(--surface2); border:1px solid var(--border); border-radius:8px; padding:.45rem .9rem; color:var(--text); font-size:.85rem; font-family:'Heebo',sans-serif; width:220px; direction:rtl; }
    .search-box input:focus { outline:none; border-color:var(--accent); }
    .search-box input::placeholder { color:var(--text-muted); }
    .btn { background:var(--accent); color:#fff; border:none; border-radius:8px; padding:.45rem 1rem; font-size:.82rem; font-family:'Heebo',sans-serif; cursor:pointer; transition:opacity .2s; }
    .btn:hover { opacity:.85; }
    .btn-sm { padding:.3rem .7rem; font-size:.78rem; border-radius:6px; }
    .btn-ghost { background:transparent; border:1px solid var(--border); color:var(--text-muted); }
    .btn-ghost:hover { border-color:var(--accent); color:var(--accent); opacity:1; }
    .market-status { display:flex; align-items:center; gap:.5rem; font-size:.75rem; color:var(--text-muted); }
    .status-dot { width:7px; height:7px; border-radius:50%; background:var(--red); }
    .status-dot.open { background:var(--green); animation:blink 2s infinite; }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.3} }

    /*  LAYOUT  */
    .layout { display:grid; grid-template-columns:260px 1fr 280px; height:calc(100vh - 96px); }
    .sidebar { background:var(--surface); border-left:1px solid var(--border); overflow-y:auto; padding:1rem; display:flex; flex-direction:column; gap:1.5rem; }
    .sidebar::-webkit-scrollbar { width:4px; }
    .sidebar::-webkit-scrollbar-thumb { background:var(--border); border-radius:4px; }
    .section-title { font-size:.72rem; font-weight:600; color:var(--text-muted); text-transform:uppercase; letter-spacing:1px; margin-bottom:.75rem; }
    .index-item { display:flex; justify-content:space-between; align-items:center; padding:.6rem .75rem; border-radius:8px; cursor:pointer; transition:background .15s; border:1px solid transparent; }
    .index-item:hover,.index-item.active { background:var(--surface2); border-color:var(--border); }
    .index-item.active { border-color:var(--accent); }
    .index-name { font-size:.82rem; font-weight:600; }
    .badge { font-size:.72rem; padding:.15rem .45rem; border-radius:4px; font-weight:600; }
    .badge.up { background:rgba(38,166,154,.15); color:var(--green); }
    .badge.down { background:rgba(239,83,80,.15); color:var(--red); }
    .watch-item { display:flex; justify-content:space-between; align-items:center; padding:.55rem .75rem; border-radius:8px; cursor:pointer; transition:background .15s; }
    .watch-item:hover { background:var(--surface2); }
    .watch-sym { font-size:.85rem; font-weight:700; }
    .watch-price { font-size:.82rem; font-weight:600; }
    .watch-chg { font-size:.72rem; }
    .watch-chg.up { color:var(--green); }
    .watch-chg.down { color:var(--red); }
    .add-row { display:flex; gap:.4rem; margin-top:.5rem; }
    .add-row input { flex:1; background:var(--surface2); border:1px solid var(--border); border-radius:6px; padding:.4rem .6rem; color:var(--text); font-size:.8rem; font-family:'Heebo',sans-serif; direction:ltr; }
    .add-row input:focus { outline:none; border-color:var(--accent); }
    .remove-btn { background:none; border:none; color:var(--text-muted); cursor:pointer; font-size:.75rem; padding:2px 5px; border-radius:4px; }
    .remove-btn:hover { color:var(--red); background:rgba(239,83,80,.1); }
    .main-area { background:var(--bg); overflow-y:auto; padding:1.25rem; display:flex; flex-direction:column; gap:1.25rem; }
    .cards-row { display:grid; grid-template-columns:repeat(4,1fr); gap:.85rem; }
    .stock-card { background:var(--surface); border:1px solid var(--border); border-radius:12px; padding:1rem; cursor:pointer; transition:border-color .2s,transform .15s; min-height:90px; }
    .stock-card:hover { border-color:var(--accent); transform:translateY(-2px); }
    .stock-card.active { border-color:var(--accent); background:var(--surface2); }
    .stock-card.skeleton { animation:pulse 1.5s infinite; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.4} }
    .card-symbol { font-size:.75rem; color:var(--text-muted); font-weight:600; letter-spacing:.5px; }
    .card-name { font-size:.82rem; font-weight:700; margin:.2rem 0; white-space:nowrap; overflow:hidden; text-overflow:ellipsis; }
    .card-price { font-size:1.1rem; font-weight:700; margin:.3rem 0 .15rem; }
    .card-change { font-size:.78rem; font-weight:600; }
    .card-change.up { color:var(--green); }
    .card-change.down { color:var(--red); }
    .chart-panel { background:var(--surface); border:1px solid var(--border); border-radius:12px; overflow:hidden; }
    .chart-header { padding:1rem 1.25rem .75rem; display:flex; justify-content:space-between; align-items:center; border-bottom:1px solid var(--border); }
    .chart-title-group h2 { font-size:1rem; font-weight:700; }
    .chart-subtitle { font-size:.8rem; color:var(--text-muted); margin-top:2px; }
    .chart-controls { display:flex; gap:.4rem; }
    .ctrl-btn { background:var(--surface2); border:1px solid var(--border); color:var(--text-muted); border-radius:6px; padding:.3rem .7rem; font-size:.75rem; cursor:pointer; font-family:'Heebo',sans-serif; transition:all .15s; }
    .ctrl-btn:hover,.ctrl-btn.active { background:var(--accent); border-color:var(--accent); color:#fff; }
    #chart { width:100%; }
    .news-panel { background:var(--surface); border:1px solid var(--border); border-radius:12px; overflow:hidden; }
    .news-header { padding:.85rem 1.25rem; border-bottom:1px solid var(--border); font-size:.85rem; font-weight:600; }
    .news-list { padding:.5rem; }
    .news-item { padding:.7rem .75rem; border-radius:8px; transition:background .15s; }
    .news-item:hover { background:var(--surface2); }
    .news-item a { color:var(--text); text-decoration:none; font-size:.83rem; line-height:1.45; display:block; margin:.25rem 0; }
    .news-item a:hover { color:var(--accent); }
    .news-meta { font-size:.72rem; color:var(--text-muted); }
    .right-sidebar { background:var(--surface); border-right:1px solid var(--border); overflow-y:auto; padding:1rem; display:flex; flex-direction:column; gap:1.5rem; }
    .right-sidebar::-webkit-scrollbar { width:4px; }
    .right-sidebar::-webkit-scrollbar-thumb { background:var(--border); border-radius:4px; }
    .port-item { background:var(--surface2); border:1px solid var(--border); border-radius:8px; padding:.65rem .8rem; margin-bottom:.5rem; }
    .port-sym { font-size:.82rem; font-weight:700; }
    .port-detail { font-size:.72rem; color:var(--text-muted); display:block; margin-top:2px; }
    .port-pnl { font-size:.8rem; font-weight:600; display:block; margin-top:4px; }
    .port-pnl.up { color:var(--green); }
    .port-pnl.down { color:var(--red); }
    .port-total { font-size:.82rem; font-weight:600; padding:.5rem 0; border-top:1px solid var(--border); }
    .form-group { display:flex; flex-direction:column; gap:.4rem; margin-bottom:.5rem; }
    .form-group input,.form-group select { background:var(--surface2); border:1px solid var(--border); border-radius:6px; padding:.4rem .65rem; color:var(--text); font-size:.8rem; font-family:'Heebo',sans-serif; direction:ltr; }
    .form-group input:focus,.form-group select:focus { outline:none; border-color:var(--accent); }
    .form-group input::placeholder { color:var(--text-muted); }
    .form-group label { font-size:.75rem; color:var(--text-muted); }
    .divider { height:1px; background:var(--border); }
    ::-webkit-scrollbar { width:5px; }
    ::-webkit-scrollbar-track { background:transparent; }
    ::-webkit-scrollbar-thumb { background:var(--border); border-radius:4px; }
    @media (max-width:1100px) { .layout { grid-template-columns:220px 1fr; } .right-sidebar { display:none; } }
    @media (max-width:700px)  { .layout { grid-template-columns:1fr; } .sidebar { display:none; } .cards-row { grid-template-columns:repeat(2,1fr); } }
  </style>
</head>
<body>

<!--  AUTH  -->
<div id="authOverlay">
  <div class="auth-glow"></div>
  <div class="auth-card">
    <div class="auth-logo">Nex<span>Trade</span></div>
    <div class="auth-tagline">פלטפורמת המסחר המובילה לשוק הישראלי &#127470;&#127473;</div>

    <div class="auth-tabs">
      <div class="auth-tab active" id="tabLogin"  onclick="switchTab('login')">כניסה</div>
      <div class="auth-tab"        id="tabSignup" onclick="switchTab('signup')">הרשמה</div>
    </div>

    <!--  LOGIN  -->
    <form class="auth-form" id="loginForm" onsubmit="handleLogin(event)">
      <div class="field-group">
        <label for="loginEmail">אימייל</label>
        <input id="loginEmail" type="email" placeholder="your@email.com" autocomplete="email" required />
      </div>
      <div class="field-group">
        <label for="loginPassword">סיסמה</label>
        <div class="pw-wrap">
          <input id="loginPassword" type="password" placeholder="הכנס סיסמה" autocomplete="current-password" required />
          <button type="button" class="eye-btn" onclick="toggleEye('loginPassword',this)" title="הצג/הסתר סיסמה">
            <svg id="eye-login" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
            </svg>
          </button>
        </div>
      </div>
      <div class="msg-error" id="loginError"></div>
      <button type="submit" class="auth-btn">כניסה &#8594;</button>
      <div class="forgot-link"><a onclick="switchTab('forgot')">&#128274; שכחתי סיסמה</a></div>
      <div class="auth-divider">או</div>
      <button type="button" class="demo-btn" onclick="demoLogin()">&#9889; כניסה כמשתמש Demo</button>
    </form>

    <!--  SIGNUP  -->
    <form class="auth-form hidden" id="signupForm" onsubmit="handleSignup(event)">
      <div class="field-group">
        <label for="signupName">שם מלא</label>
        <input id="signupName" type="text" placeholder="ישראל ישראלי" autocomplete="name" required />
      </div>
      <div class="field-group">
        <label for="signupEmail">אימייל</label>
        <input id="signupEmail" type="email" placeholder="your@email.com" autocomplete="email" required />
      </div>
      <div class="field-group">
        <label for="signupPassword">סיסמה</label>
        <div class="pw-wrap">
          <input id="signupPassword" type="password" placeholder="לפחות 6 תווים" autocomplete="new-password" oninput="checkStrength(this.value)" required />
          <button type="button" class="eye-btn" onclick="toggleEye('signupPassword',this)" title="הצג/הסתר סיסמה">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
            </svg>
          </button>
        </div>
        <div class="strength-bar"><div class="strength-fill" id="strengthFill"></div></div>
        <div class="strength-text" id="strengthText"></div>
      </div>
      <div class="field-group">
        <label for="signupConfirm">אימות סיסמה</label>
        <div class="pw-wrap">
          <input id="signupConfirm" type="password" placeholder="חזור על הסיסמה" autocomplete="new-password" required />
          <button type="button" class="eye-btn" onclick="toggleEye('signupConfirm',this)" title="הצג/הסתר סיסמה">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
              <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"/><circle cx="12" cy="12" r="3"/>
            </svg>
          </button>
        </div>
      </div>
      <div class="msg-error" id="signupError"></div>
      <div class="msg-ok"    id="signupSuccess"></div>
      <button type="submit" class="auth-btn">הרשמה &#10003;</button>
    </form>

    <!--  FORGOT PASSWORD  -->
    <form class="auth-form hidden" id="forgotForm" onsubmit="handleForgot(event)">
      <a class="back-link" onclick="switchTab('login')">&#8592; חזרה לכניסה</a>
      <div class="field-group">
        <label for="forgotEmail">הכנס את האימייל שנרשמת איתו</label>
        <input id="forgotEmail" type="email" placeholder="your@email.com" autocomplete="email" required />
      </div>
      <div class="msg-error" id="forgotError"></div>
      <div class="msg-ok"    id="forgotSuccess"></div>
      <button type="submit" class="auth-btn">שחזר סיסמה &#128274;</button>
    </form>

    <div class="auth-footer">NexTrade &copy; 2026 &middot; כל הזכויות שמורות</div>
  </div>
</div>

<!--  APP  -->
<div id="appContainer" style="display:none">
  <div class="ticker-wrap"><div class="ticker-inner" id="tickerInner">טוען נתונים...</div></div>

  <header class="topbar">
    <div class="logo">Nex<span>Trade</span> <small style="font-size:.65rem;color:var(--text-muted);font-weight:400">ת"א</small></div>
    <div class="topbar-center search-box">
      <input id="searchInput" placeholder="חפש מניה..." />
      <button class="btn btn-sm" onclick="searchStock()">חפש</button>
      <div class="market-status"><div class="status-dot" id="marketDot"></div><span id="marketStatusText">בודק...</span></div>
    </div>
    <div class="topbar-right">
      <div class="user-badge">
        <div class="user-avatar" id="userAvatar">?</div>
        <span class="user-name" id="userNameDisplay"></span>
      </div>
      <button class="logout-btn" onclick="handleLogout()">יציאה</button>
    </div>
  </header>

  <div class="layout">
    <aside class="sidebar">
      <div>
        <div class="section-title">&#128200; מדדי תל אביב</div>
        <div id="indicesList"></div>
      </div>
      <div class="divider"></div>
      <div>
        <div class="section-title">&#11088; רשימת מעקב</div>
        <ul id="watchlist" style="list-style:none;"></ul>
        <div class="add-row">
          <input id="watchlistInput" placeholder="סמל מניה" maxlength="10" />
          <button class="btn btn-sm" onclick="addToWatchlist()">+</button>
        </div>
      </div>
    </aside>

    <main class="main-area">
      <div class="cards-row" id="cardsGrid"></div>
      <div class="chart-panel">
        <div class="chart-header">
          <div class="chart-title-group">
            <h2 id="chartTitle">בחר מניה</h2>
            <div class="chart-subtitle" id="chartSubtitle"></div>
          </div>
          <div class="chart-controls">
            <button class="ctrl-btn active" onclick="setChartType('line',this)">קו</button>
            <button class="ctrl-btn" onclick="setChartType('candle',this)">נרות</button>
            <button class="ctrl-btn" onclick="setChartType('bar',this)">עמודות</button>
          </div>
        </div>
        <div id="chart"></div>
      </div>
      <div class="news-panel">
        <div class="news-header">&#128240; חדשות שוק <span id="newsSymbol" style="color:var(--text-muted)"></span></div>
        <div class="news-list" id="newsList"><div style="padding:1rem;color:var(--text-muted);font-size:.82rem">טוען חדשות...</div></div>
      </div>
    </main>

    <aside class="right-sidebar">
      <div>
        <div class="section-title">&#128188; תיק השקעות</div>
        <ul id="portfolioList" style="list-style:none;"></ul>
        <div class="port-total" id="portfolioTotal"></div>
        <div class="form-group"><label>סמל</label><input id="portSymbol" placeholder="TEVA" /></div>
        <div class="form-group"><label>כמות מניות</label><input id="portShares" type="number" placeholder="100" /></div>
        <div class="form-group"><label>מחיר קנייה</label><input id="portPrice" type="number" placeholder="50.00" /></div>
        <button class="btn btn-sm" style="width:100%" onclick="addToPortfolio()">הוסף לתיק</button>
      </div>
      <div class="divider"></div>
      <div>
        <div class="section-title">&#128276; התראות מחיר</div>
        <ul id="alertsList" style="list-style:none;"></ul>
        <div class="form-group"><label>סמל</label><input id="alertSymbol" placeholder="NICE" /></div>
        <div class="form-group"><label>תנאי</label>
          <select id="alertCondition">
            <option value="above">מעל המחיר</option>
            <option value="below">מתחת למחיר</option>
          </select>
        </div>
        <div class="form-group"><label>מחיר יעד</label><input id="alertPrice" type="number" placeholder="100" /></div>
        <button class="btn btn-sm btn-ghost" style="width:100%" onclick="addAlert()">הוסף התראה</button>
      </div>
    </aside>
  </div>
</div>

<script src="main.js"></script>
</body>
</html>
