<!DOCTYPE html>
<html lang="he" dir="rtl">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>NexTrade  הבורסה הישראלית</title>
  <script src="https://unpkg.com/lightweight-charts/dist/lightweight-charts.standalone.production.js"></script>
  <link href="https://fonts.googleapis.com/css2?family=Heebo:wght@300;400;500;600;700&display=swap" rel="stylesheet" />
  <style>
    *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }
    :root {
      --bg: #0b0e17; --surface: #131722; --surface2: #1a1f2e;
      --border: #252d3d; --accent: #2962ff; --green: #26a69a;
      --red: #ef5350; --text: #d1d4dc; --text-muted: #6b7280; --gold: #f5a623;
    }
    body { font-family: "Heebo", sans-serif; background: var(--bg); color: var(--text); min-height: 100vh; overflow-x: hidden; }

    /* AUTH OVERLAY */
    #authOverlay {
      position: fixed; inset: 0; background: var(--bg); z-index: 9999;
      display: flex; align-items: center; justify-content: center;
    }
    .auth-glow {
      position: absolute; width: 500px; height: 500px;
      background: radial-gradient(circle, rgba(41,98,255,.18) 0%, transparent 70%);
      top: 50%; left: 50%; transform: translate(-50%,-50%); pointer-events: none;
    }
    .auth-card {
      position: relative; background: var(--surface); border: 1px solid var(--border);
      border-radius: 20px; padding: 2.5rem 2.25rem; width: 100%; max-width: 400px;
      box-shadow: 0 25px 60px rgba(0,0,0,.5);
    }
    .auth-logo { text-align: center; font-size: 2rem; font-weight: 700; color: var(--accent); margin-bottom: 0.25rem; letter-spacing: -1px; }
    .auth-logo span { color: var(--gold); }
    .auth-tagline { text-align: center; font-size: 0.8rem; color: var(--text-muted); margin-bottom: 2rem; }
    .auth-tabs { display: flex; background: var(--surface2); border-radius: 10px; padding: 4px; margin-bottom: 1.75rem; gap: 4px; }
    .auth-tab { flex: 1; text-align: center; padding: 0.5rem; font-size: 0.85rem; font-weight: 600; cursor: pointer; border-radius: 7px; color: var(--text-muted); transition: all .2s; user-select: none; }
    .auth-tab.active { background: var(--accent); color: #fff; }
    .auth-form { display: flex; flex-direction: column; gap: 1rem; }
    .auth-form.hidden { display: none; }
    .field-group { display: flex; flex-direction: column; gap: 0.4rem; }
    .field-group label { font-size: 0.78rem; color: var(--text-muted); font-weight: 600; }
    .field-group input {
      background: var(--surface2); border: 1px solid var(--border); border-radius: 10px;
      padding: 0.7rem 1rem; color: var(--text); font-size: 0.88rem;
      font-family: "Heebo", sans-serif; direction: rtl; transition: border-color .2s; width: 100%;
    }
    .field-group input:focus { outline: none; border-color: var(--accent); box-shadow: 0 0 0 3px rgba(41,98,255,.15); }
    .field-group input::placeholder { color: var(--text-muted); }
    .field-group input.error { border-color: var(--red); }
    .auth-error { background: rgba(239,83,80,.12); border: 1px solid rgba(239,83,80,.3); border-radius: 8px; padding: 0.6rem 0.9rem; font-size: 0.8rem; color: var(--red); display: none; }
    .auth-error.show { display: block; }
    .auth-success { background: rgba(38,166,154,.12); border: 1px solid rgba(38,166,154,.3); border-radius: 8px; padding: 0.6rem 0.9rem; font-size: 0.8rem; color: var(--green); display: none; }
    .auth-success.show { display: block; }
    .auth-btn { background: var(--accent); color: #fff; border: none; border-radius: 10px; padding: 0.75rem; font-size: 0.9rem; font-weight: 700; font-family: "Heebo", sans-serif; cursor: pointer; transition: opacity .2s, transform .1s; margin-top: 0.25rem; }
    .auth-btn:hover { opacity: 0.88; }
    .auth-btn:active { transform: scale(.98); }
    .auth-btn:disabled { opacity: .5; cursor: not-allowed; }
    .auth-divider { display: flex; align-items: center; gap: 0.75rem; color: var(--text-muted); font-size: 0.75rem; }
    .auth-divider::before, .auth-divider::after { content: ""; flex: 1; height: 1px; background: var(--border); }
    .demo-btn { background: transparent; border: 1px solid var(--border); color: var(--text-muted); border-radius: 10px; padding: 0.65rem; font-size: 0.82rem; font-family: "Heebo", sans-serif; cursor: pointer; transition: all .2s; text-align: center; width: 100%; }
    .demo-btn:hover { border-color: var(--gold); color: var(--gold); }
    .pass-wrap { position: relative; }
    .pass-wrap input { padding-left: 2.5rem; }
    .toggle-pass { position: absolute; left: 0.8rem; top: 50%; transform: translateY(-50%); background: none; border: none; cursor: pointer; color: var(--text-muted); font-size: 1rem; padding: 0; line-height: 1; }
    .toggle-pass:hover { color: var(--text); }
    .strength-bar { height: 3px; border-radius: 2px; background: var(--border); margin-top: 0.4rem; overflow: hidden; }
    .strength-fill { height: 100%; border-radius: 2px; transition: width .3s, background .3s; width: 0%; }
    .strength-text { font-size: 0.7rem; color: var(--text-muted); margin-top: 0.25rem; }
    .auth-footer { text-align: center; font-size: 0.72rem; color: var(--text-muted); margin-top: 1.5rem; }

    /* USER BADGE */
    .user-badge { display: flex; align-items: center; gap: 0.6rem; }
    .user-avatar { width: 32px; height: 32px; border-radius: 50%; background: var(--accent); display: flex; align-items: center; justify-content: center; font-size: 0.8rem; font-weight: 700; color: #fff; }
    .user-name { font-size: 0.82rem; color: var(--text-muted); }
    .logout-btn { background: transparent; border: 1px solid var(--border); color: var(--text-muted); border-radius: 7px; padding: 0.3rem 0.65rem; font-size: 0.75rem; font-family: "Heebo", sans-serif; cursor: pointer; transition: all .2s; }
    .logout-btn:hover { border-color: var(--red); color: var(--red); }

    /* TICKER */
    .ticker-wrap { background: var(--surface); border-bottom: 1px solid var(--border); overflow: hidden; height: 36px; display: flex; align-items: center; }
    .ticker-inner { display: inline-block; white-space: nowrap; animation: ticker 60s linear infinite; font-size: 0.78rem; color: var(--text-muted); padding-right: 100%; }
    @keyframes ticker { 0%{transform:translateX(0)} 100%{transform:translateX(-50%)} }

    /* TOPBAR */
    .topbar { background: var(--surface); border-bottom: 1px solid var(--border); padding: 0 1.5rem; height: 60px; display: flex; align-items: center; justify-content: space-between; position: sticky; top: 0; z-index: 100; }
    .logo { font-size: 1.4rem; font-weight: 700; color: var(--accent); letter-spacing: -0.5px; }
    .logo span { color: var(--gold); }
    .topbar-right { display: flex; gap: 0.75rem; align-items: center; }
    .search-box { display: flex; gap: 0.5rem; align-items: center; }
    .search-box input { background: var(--surface2); border: 1px solid var(--border); border-radius: 8px; padding: 0.45rem 0.9rem; color: var(--text); font-size: 0.85rem; font-family: "Heebo", sans-serif; width: 220px; direction: rtl; }
    .search-box input:focus { outline: none; border-color: var(--accent); }
    .search-box input::placeholder { color: var(--text-muted); }
    .btn { background: var(--accent); color: #fff; border: none; border-radius: 8px; padding: 0.45rem 1rem; font-size: 0.82rem; font-family: "Heebo", sans-serif; cursor: pointer; transition: opacity .2s; }
    .btn:hover { opacity: 0.85; }
    .btn-sm { padding: 0.3rem 0.7rem; font-size: 0.78rem; border-radius: 6px; }
    .btn-ghost { background: transparent; border: 1px solid var(--border); color: var(--text-muted); }
    .btn-ghost:hover { border-color: var(--accent); color: var(--accent); opacity: 1; }
    .market-status { display: flex; align-items: center; gap: 0.5rem; font-size: 0.75rem; color: var(--text-muted); }
    .status-dot { width:7px; height:7px; border-radius:50%; background: var(--red); }
    .status-dot.open { background: var(--green); animation: blink 2s infinite; }
    @keyframes blink { 0%,100%{opacity:1} 50%{opacity:.3} }

    /* LAYOUT */
    .layout { display: grid; grid-template-columns: 260px 1fr 280px; height: calc(100vh - 96px); }
    .sidebar { background: var(--surface); border-left: 1px solid var(--border); overflow-y: auto; padding: 1rem; display: flex; flex-direction: column; gap: 1.5rem; }
    .section-title { font-size: 0.72rem; font-weight: 600; color: var(--text-muted); text-transform: uppercase; letter-spacing: 1px; margin-bottom: 0.75rem; }
    .index-item { display: flex; justify-content: space-between; align-items: center; padding: 0.6rem 0.75rem; border-radius: 8px; cursor: pointer; transition: background .15s; border: 1px solid transparent; }
    .index-item:hover, .index-item.active { background: var(--surface2); border-color: var(--border); }
    .index-item.active { border-color: var(--accent); }
    .index-name { font-size: 0.82rem; font-weight: 600; }
    .badge { font-size: 0.72rem; padding: 0.15rem 0.45rem; border-radius: 4px; font-weight: 600; }
    .badge.up { background: rgba(38,166,154,.15); color: var(--green); }
    .badge.down { background: rgba(239,83,80,.15); color: var(--red); }
    .watch-item { display: flex; justify-content: space-between; align-items: center; padding: 0.55rem 0.75rem; border-radius: 8px; cursor: pointer; transition: background .15s; }
    .watch-item:hover { background: var(--surface2); }
    .watch-sym { font-size: 0.85rem; font-weight: 700; }
    .watch-price { font-size: 0.82rem; font-weight: 600; }
    .watch-chg { font-size: 0.72rem; }
    .watch-chg.up { color: var(--green); }
    .watch-chg.down { color: var(--red); }
    .add-row { display: flex; gap: 0.4rem; margin-top: 0.5rem; }
    .add-row input { flex: 1; background: var(--surface2); border: 1px solid var(--border); border-radius: 6px; padding: 0.4rem 0.6rem; color: var(--text); font-size: 0.8rem; font-family: "Heebo", sans-serif; direction: ltr; }
    .add-row input:focus { outline: none; border-color: var(--accent); }
    .remove-btn { background: none; border: none; color: var(--text-muted); cursor: pointer; font-size: 0.75rem; padding: 2px 5px; border-radius: 4px; }
    .remove-btn:hover { color: var(--red); background: rgba(239,83,80,.1); }

    /* MAIN */
    .main-area { background: var(--bg); overflow-y: auto; padding: 1.25rem; display: flex; flex-direction: column; gap: 1.25rem; }
    .cards-row { display: grid; grid-template-columns: repeat(4, 1fr); gap: 0.85rem; }
    .stock-card { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; padding: 1rem; cursor: pointer; transition: border-color .2s, transform .15s; min-height: 90px; }
    .stock-card:hover { border-color: var(--accent); transform: translateY(-2px); }
    .stock-card.active { border-color: var(--accent); background: var(--surface2); }
    .stock-card.skeleton { animation: pulse 1.5s infinite; }
    @keyframes pulse { 0%,100%{opacity:1} 50%{opacity:.4} }
    .card-symbol { font-size: 0.75rem; color: var(--text-muted); font-weight: 600; }
    .card-name { font-size: 0.82rem; font-weight: 700; margin: 0.2rem 0; white-space: nowrap; overflow: hidden; text-overflow: ellipsis; }
    .card-price { font-size: 1.1rem; font-weight: 700; margin: 0.3rem 0 0.15rem; }
    .card-change { font-size: 0.78rem; font-weight: 600; }
    .card-change.up { color: var(--green); }
    .card-change.down { color: var(--red); }
    .chart-panel { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
    .chart-header { padding: 1rem 1.25rem 0.75rem; display: flex; justify-content: space-between; align-items: center; border-bottom: 1px solid var(--border); }
    .chart-title-group h2 { font-size: 1rem; font-weight: 700; }
    .chart-subtitle { font-size: 0.8rem; color: var(--text-muted); margin-top: 2px; }
    .chart-controls { display: flex; gap: 0.4rem; }
    .ctrl-btn { background: var(--surface2); border: 1px solid var(--border); color: var(--text-muted); border-radius: 6px; padding: 0.3rem 0.7rem; font-size: 0.75rem; cursor: pointer; font-family: "Heebo", sans-serif; transition: all .15s; }
    .ctrl-btn:hover, .ctrl-btn.active { background: var(--accent); border-color: var(--accent); color: #fff; }
    #chart { width: 100%; }
    .news-panel { background: var(--surface); border: 1px solid var(--border); border-radius: 12px; overflow: hidden; }
    .news-header { padding: 0.85rem 1.25rem; border-bottom: 1px solid var(--border); font-size: 0.85rem; font-weight: 600; }
    .news-list { padding: 0.5rem; }
    .news-item { padding: 0.7rem 0.75rem; border-radius: 8px; transition: background .15s; }
    .news-item:hover { background: var(--surface2); }
    .news-item a { color: var(--text); text-decoration: none; font-size: 0.83rem; line-height: 1.45; display: block; margin: 0.25rem 0; }
    .news-item a:hover { color: var(--accent); }
    .news-meta { font-size: 0.72rem; color: var(--text-muted); }

    /* RIGHT SIDEBAR */
    .right-sidebar { background: var(--surface); border-right: 1px solid var(--border); overflow-y: auto; padding: 1rem; display: flex; flex-direction: column; gap: 1.5rem; }
    .port-item { background: var(--surface2); border: 1px solid var(--border); border-radius: 8px; padding: 0.65rem 0.8rem; margin-bottom: 0.5rem; }
    .port-sym { font-size: 0.82rem; font-weight: 700; }
    .port-detail { font-size: 0.72rem; color: var(--text-muted); display: block; margin-top: 2px; }
    .port-pnl { font-size: 0.8rem; font-weight: 600; display: block; margin-top: 4px; }
    .port-pnl.up { color: var(--green); }
    .port-pnl.down { color: var(--red); }
    .port-total { font-size: 0.82rem; font-weight: 600; padding: 0.5rem 0; border-top: 1px solid var(--border); }
    .form-group { display: flex; flex-direction: column; gap: 0.4rem; margin-bottom: 0.5rem; }
    .form-group input, .form-group select { background: var(--surface2); border: 1px solid var(--border); border-radius: 6px; padding: 0.4rem 0.65rem; color: var(--text); font-size: 0.8rem; font-family: "Heebo", sans-serif; direction: ltr; }
    .form-group input:focus, .form-group select:focus { outline: none; border-color: var(--accent); }
    .form-group input::placeholder { color: var(--text-muted); }
    .form-group label { font-size: 0.75rem; color: var(--text-muted); }
    .alert-triggered { font-size: 0.68rem; background: rgba(245,166,35,.15); color: var(--gold); padding: 0.1rem 0.4rem; border-radius: 4px; font-weight: 700; }
    .divider { height: 1px; background: var(--border); }
    ::-webkit-scrollbar { width: 5px; }
    ::-webkit-scrollbar-track { background: transparent; }
    ::-webkit-scrollbar-thumb { background: var(--border); border-radius: 4px; }
    @media (max-width: 1100px) { .layout { grid-template-columns: 220px 1fr; } .right-sidebar { display: none; } }
    @media (max-width: 700px) { .layout { grid-template-columns: 1fr; } .sidebar { display: none; } .cards-row { grid-template-columns: repeat(2,1fr); } }
    /* FORGOT PASSWORD */
    .forgot-link { text-align: left; margin-top: -0.5rem; }
    .forgot-link button { background: none; border: none; color: var(--text-muted); font-size: 0.75rem; cursor: pointer; font-family: "Heebo", sans-serif; text-decoration: underline; padding: 0; }
    .forgot-link button:hover { color: var(--accent); }

    /* ADMIN PANEL */
    #adminOverlay { position: fixed; inset: 0; background: rgba(0,0,0,.75); z-index: 10000; display: none; align-items: center; justify-content: center; }
    #adminOverlay.show { display: flex; }
    .admin-card { background: var(--surface); border: 1px solid var(--border); border-radius: 20px; padding: 2rem; width: 100%; max-width: 680px; max-height: 85vh; overflow-y: auto; box-shadow: 0 25px 60px rgba(0,0,0,.6); position: relative; }
    .admin-header { display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem; }
    .admin-title { font-size: 1.1rem; font-weight: 700; }
    .admin-close { background: none; border: none; color: var(--text-muted); font-size: 1.5rem; cursor: pointer; line-height: 1; padding: 0; }
    .admin-close:hover { color: var(--red); }
    .admin-stats { display: grid; grid-template-columns: repeat(3,1fr); gap: 0.75rem; margin-bottom: 1.5rem; }
    .admin-stat { background: var(--surface2); border: 1px solid var(--border); border-radius: 10px; padding: 0.85rem; text-align: center; }
    .admin-stat-val { font-size: 1.6rem; font-weight: 700; color: var(--accent); }
    .admin-stat-label { font-size: 0.72rem; color: var(--text-muted); margin-top: 2px; }
    .admin-search { background: var(--surface2); border: 1px solid var(--border); border-radius: 8px; padding: 0.5rem 0.9rem; color: var(--text); font-size: 0.82rem; font-family: "Heebo", sans-serif; width: 100%; margin-bottom: 1rem; direction: rtl; }
    .admin-search:focus { outline: none; border-color: var(--accent); }
    .admin-table { width: 100%; border-collapse: collapse; font-size: 0.82rem; }
    .admin-table th { text-align: right; padding: 0.5rem 0.75rem; color: var(--text-muted); font-size: 0.7rem; font-weight: 600; text-transform: uppercase; letter-spacing: .5px; border-bottom: 1px solid var(--border); }
    .admin-table td { padding: 0.65rem 0.75rem; border-bottom: 1px solid rgba(37,45,61,.5); vertical-align: middle; }
    .admin-table tr:last-child td { border-bottom: none; }
    .admin-table tr:hover td { background: var(--surface2); }
    .role-admin { background: rgba(245,166,35,.15); color: var(--gold); font-size: 0.68rem; padding: 0.15rem 0.5rem; border-radius: 4px; font-weight: 700; }
    .role-user  { background: rgba(41,98,255,.15);  color: var(--accent); font-size: 0.68rem; padding: 0.15rem 0.5rem; border-radius: 4px; font-weight: 700; }
    .admin-del  { background: none; border: none; color: var(--text-muted); cursor: pointer; font-size: 0.8rem; padding: 3px 7px; border-radius: 4px; }
    .admin-del:hover { color: var(--red); background: rgba(239,83,80,.12); }
    .admin-btn { background: var(--surface2); border: 1px solid var(--border); color: var(--text-muted); border-radius: 7px; padding: 0.3rem 0.7rem; font-size: 0.75rem; font-family: "Heebo", sans-serif; cursor: pointer; transition: all .2s; }
    .admin-btn:hover { border-color: var(--gold); color: var(--gold); }
  </style>
</head>
<body>

<!-- AUTH OVERLAY -->
<div id="authOverlay">
  <div class="auth-glow"></div>
  <div class="auth-card">
    <div class="auth-logo">Nex<span>Trade</span></div>
    <div class="auth-tagline">פלטפורמת המסחר המובילה לשוק הישראלי</div>
    <div class="auth-tabs">
      <div class="auth-tab active" id="tabLogin"  onclick="switchTab('login')">כניסה</div>
      <div class="auth-tab"        id="tabSignup" onclick="switchTab('signup')">הרשמה</div>
      <div class="auth-tab"        id="tabForgot" onclick="switchTab('forgot')">שחזור סיסמה</div>
    </div>

    <!-- LOGIN -->
    <form class="auth-form" id="loginForm" onsubmit="handleLogin(event)">
      <div class="field-group">
        <label>שם משתמש</label>
        <input id="loginUsername" type="text" placeholder="הכנס שם משתמש" autocomplete="username" />
      </div>
      <div class="field-group">
        <label>סיסמה</label>
        <div class="pass-wrap">
          <input id="loginPassword" type="password" placeholder="הכנס סיסמה" autocomplete="current-password" />
          <button type="button" class="toggle-pass" onclick="togglePass('loginPassword',this)">&#128065;</button>
        </div>
      </div>
      <div class="forgot-link">
        <button type="button" onclick="switchTab('forgot')">שכחתי סיסמה</button>
      </div>
      <div class="auth-error" id="loginError"></div>
      <button type="submit" class="auth-btn">כניסה</button>
      <div class="auth-divider">או</div>
      <button type="button" class="demo-btn" onclick="demoLogin()">כניסה כמשתמש Demo</button>
    </form>

    <!-- SIGNUP -->
    <form class="auth-form hidden" id="signupForm" onsubmit="handleSignup(event)">
      <div class="field-group">
        <label>שם מלא</label>
        <input id="signupName" type="text" placeholder="ישראל ישראלי" autocomplete="name" />
      </div>
      <div class="field-group">
        <label>שם משתמש</label>
        <input id="signupUsername" type="text" placeholder="בחר שם משתמש" autocomplete="username" />
      </div>
      <div class="field-group">
        <label>סיסמה</label>
        <div class="pass-wrap">
          <input id="signupPassword" type="password" placeholder="לפחות 6 תווים"
                 autocomplete="new-password" oninput="checkStrength(this.value)" />
          <button type="button" class="toggle-pass" onclick="togglePass('signupPassword',this)">&#128065;</button>
        </div>
        <div class="strength-bar"><div class="strength-fill" id="strengthFill"></div></div>
        <div class="strength-text" id="strengthText"></div>
      </div>
      <div class="field-group">
        <label>אימות סיסמה</label>
        <div class="pass-wrap">
          <input id="signupConfirm" type="password" placeholder="חזור על הסיסמה" autocomplete="new-password" />
          <button type="button" class="toggle-pass" onclick="togglePass('signupConfirm',this)">&#128065;</button>
        </div>
      </div>
      <div class="auth-error"   id="signupError"></div>
      <div class="auth-success" id="signupSuccess"></div>
      <button type="submit" class="auth-btn">הרשמה</button>
    </form>


    <!-- FORGOT PASSWORD -->
    <form class="auth-form hidden" id="forgotForm" onsubmit="handleForgot(event)">
      <div style="text-align:center;font-size:2rem;margin-bottom:.5rem">&#128274;</div>
      <div style="text-align:center;font-size:.82rem;color:var(--text-muted);margin-bottom:.5rem">הכנס שם משתמש ואימייל שנרשמת איתו</div>
      <div class="field-group">
        <label>שם משתמש</label>
        <input id="forgotUsername" type="text" placeholder="שם המשתמש שלך" autocomplete="username" />
      </div>
      <div class="field-group">
        <label>אימייל</label>
        <input id="forgotEmail" type="email" placeholder="המייל שנרשמת איתו" autocomplete="email" />
      </div>
      <div class="auth-error"   id="forgotError"></div>
      <div class="auth-success" id="forgotSuccess"></div>
      <div class="forgot-result hidden" id="forgotResult"></div>
      <button type="submit" class="auth-btn">אפס סיסמה</button>
      <button type="button" class="demo-btn" style="margin-top:.25rem" onclick="switchTab('login')">חזרה לכניסה</button>
    </form>

    <div class="auth-footer">NexTrade 2026 &copy; כל הזכויות שמורות</div>
  </div>
</div>

<!-- MAIN APP -->
<div id="appContainer" style="display:none">
  <div class="ticker-wrap"><div class="ticker-inner" id="tickerInner">טוען...</div></div>

  <header class="topbar">
    <div class="logo">Nex<span>Trade</span> <small style="font-size:.65rem;color:var(--text-muted);font-weight:400">ת"א</small></div>
    <div class="search-box">
      <input id="searchInput" placeholder="חפש מניה... (לדוג TEVA, NICE)" />
      <button class="btn btn-sm" onclick="searchStock()">חפש</button>
      <div class="market-status">
        <div class="status-dot" id="marketDot"></div>
        <span id="marketStatusText">בודק...</span>
      </div>
    </div>
    <div class="topbar-right">
      <div class="user-badge">
        <div class="user-avatar" id="userAvatar"></div>
        <span class="user-name" id="userNameDisplay"></span>
      </div>
      <button class="logout-btn" onclick="handleLogout()">יציאה</button>
 <button class="admin-btn" id="adminBtn" onclick="openAdmin()" style="display:none">&#9881; ניהול</button>
    </div>
  </header>

  <div class="layout">
    <aside class="sidebar">
      <div>
        <div class="section-title">מדדי תל אביב</div>
        <div id="indicesList"></div>
      </div>
      <div class="divider"></div>
      <div>
        <div class="section-title">רשימת מעקב</div>
        <ul id="watchlist" style="list-style:none;"></ul>
        <div class="add-row">
          <input id="watchlistInput" placeholder="סמל מניה" maxlength="10" />
          <button class="btn btn-sm" onclick="addToWatchlist()">+</button>
        </div>
      </div>
    </aside>

    <main class="main-area">
      <div class="cards-row" id="cardsGrid"></div>
      <div class="chart-panel">
        <div class="chart-header">
          <div class="chart-title-group">
            <h2 id="chartTitle">בחר מניה</h2>
            <div class="chart-subtitle" id="chartSubtitle">-</div>
          </div>
          <div class="chart-controls">
            <button class="ctrl-btn active" onclick="setChartType('line',this)">קו</button>
            <button class="ctrl-btn" onclick="setChartType('candle',this)">נרות</button>
            <button class="ctrl-btn" onclick="setChartType('bar',this)">עמודות</button>
          </div>
        </div>
        <div id="chart"></div>
      </div>
      <div class="news-panel">
        <div class="news-header">חדשות שוק <span id="newsSymbol" style="color:var(--text-muted)"></span></div>
        <div class="news-list" id="newsList"><div style="padding:1rem;color:var(--text-muted);font-size:.82rem">טוען חדשות...</div></div>
      </div>
    </main>

    <aside class="right-sidebar">
      <div>
        <div class="section-title">תיק השקעות</div>
        <ul id="portfolioList" style="list-style:none;"></ul>
        <div class="port-total" id="portfolioTotal"></div>
        <div class="form-group"><label>סמל</label><input id="portSymbol" placeholder="TEVA" /></div>
        <div class="form-group"><label>כמות מניות</label><input id="portShares" type="number" placeholder="100" /></div>
        <div class="form-group"><label>מחיר קנייה</label><input id="portPrice" type="number" placeholder="50.00" /></div>
        <button class="btn btn-sm" style="width:100%" onclick="addToPortfolio()">הוסף לתיק</button>
      </div>
      <div class="divider"></div>
      <div>
        <div class="section-title">התראות מחיר</div>
        <ul id="alertsList" style="list-style:none;"></ul>
        <div class="form-group"><label>סמל</label><input id="alertSymbol" placeholder="NICE" /></div>
        <div class="form-group">
          <label>תנאי</label>
          <select id="alertCondition">
            <option value="above">מעל המחיר</option>
            <option value="below">מתחת למחיר</option>
          </select>
        </div>
        <div class="form-group"><label>מחיר יעד</label><input id="alertPrice" type="number" placeholder="100" /></div>
        <button class="btn btn-sm btn-ghost" style="width:100%" onclick="addAlert()">הוסף התראה</button>
      </div>
    </aside>
  </div>
</div>


<!-- ADMIN PANEL -->
<div id="adminOverlay">
  <div class="admin-card">
    <div class="admin-header">
      <div class="admin-title">&#9881; פאנל ניהול משתמשים</div>
      <button class="admin-close" onclick="closeAdmin()">&#10005;</button>
    </div>
    <div class="admin-stats" id="adminStats"></div>
    <input class="admin-search" id="adminSearch" placeholder="&#128269; חפש לפי שם משתמש או שם..." oninput="renderAdminTable()" />
    <table class="admin-table">
      <thead>
        <tr>
          <th>#</th>
          <th>שם מלא</th>
          <th>שם משתמש</th>
          <th>אימייל</th>
          <th>תפקיד</th>
          <th>תאריך הצטרפות</th>
          <th>פעולות</th>
        </tr>
      </thead>
      <tbody id="adminTableBody"></tbody>
    </table>
  </div>
</div>

<script src="main.js"></script>
</body>
</html>

